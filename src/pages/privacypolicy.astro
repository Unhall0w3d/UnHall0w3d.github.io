---
import { getEntry, render } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";

const page = await getEntry("pages", "privacy-policy");
if (!page) throw new Error("Privacy policy content is missing");
const { Content } = await render(page);
---

<PageLayout title={page.data.title} eyebrow="SITE POLICY">
  <Content />
</PageLayout>
