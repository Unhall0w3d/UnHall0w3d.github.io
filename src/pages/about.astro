---
import { getEntry, render } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";

const page = await getEntry("pages", "about");
if (!page) throw new Error("About page content is missing");
const { Content } = await render(page);
---

<PageLayout title={page.data.title} description="The engineer, operator, and caffeine-driven human behind NOC Thoughts." eyebrow="OPERATOR PROFILE">
  <Content />
</PageLayout>
