---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import { site } from "../config/site";
import { getCollection } from "astro:content";
import { sortPosts, type Post } from "../lib/posts";

const allPosts = sortPosts((await getCollection("posts", ({ data }) => !data.draft)) as Post[]);
const latestPosts = allPosts.slice(0, 5);
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow"><span>TRANSMISSION ACTIVE</span> INFRASTRUCTURE FIELD LOG</p>
      <h1>Where network operations meet <em>techno-sorcery.</em></h1>
      <p class="hero-deck">
        {site.tagline}. Hard-won fixes, useful scripts, and the operational
        knowledge that usually appears only after something catches fire.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/posts.html">Enter the archive</a>
        <a class="button button-ghost" href="/about.html">Identify operator</a>
      </div>
    </div>

    <aside class="signal-card" aria-label="Site signal status">
      <div class="signal-card-header">
        <span>SYSTEM SIGNAL</span>
        <span>01-A</span>
      </div>
      <button class="signal-flip" type="button" aria-pressed="false" aria-label="Kenneth Perry. Show system sigil">
        <span class="signal-flip-inner">
          <span class="signal-face signal-face-portrait" aria-hidden="true">
            <img src={site.author.avatar} width="2048" height="2048" alt="" />
            <span class="signal-face-label">OPERATOR // 01</span>
            <span class="signal-flip-prompt">TAP TO DECRYPT ↻</span>
          </span>
          <span class="signal-face signal-face-sigil" aria-hidden="true">
            <svg class="hero-sigil" viewBox="0 0 320 320">
              <circle cx="160" cy="160" r="122" />
              <circle cx="160" cy="160" r="86" />
              <path d="M160 22v276M22 160h276M62 62l196 196M258 62 62 258" />
              <path d="m160 72 76 44v88l-76 44-76-44v-88l76-44Z" />
              <path class="sigil-core" d="m124 194 36-68 36 68M132 176h56" />
            </svg>
            <span class="signal-face-label">SYSTEM SIGIL // A</span>
            <span class="signal-flip-prompt">RETURN TO OPERATOR ↻</span>
          </span>
        </span>
      </button>
      <dl class="signal-stats">
        <div><dt>FOCUS</dt><dd>UC / AUTOMATION</dd></div>
        <div><dt>ARCHIVE</dt><dd>{allPosts.length} ENTRIES</dd></div>
        <div><dt>STATE</dt><dd class="online">ONLINE</dd></div>
      </dl>
    </aside>
  </section>

  <section class="transmissions" aria-labelledby="transmissions-title">
    <header class="section-header">
      <div>
        <p class="eyebrow">LATEST SIGNALS</p>
        <h2 id="transmissions-title">Recent transmissions</h2>
      </div>
      <a class="text-link" href="/posts.html">View complete archive <span>→</span></a>
    </header>

    <PostList posts={latestPosts} numbered />
  </section>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>(".signal-flip").forEach((control) => {
    control.addEventListener("click", () => {
      const flipped = control.getAttribute("aria-pressed") !== "true";
      control.setAttribute("aria-pressed", String(flipped));
      control.setAttribute(
        "aria-label",
        flipped ? "System sigil. Show Kenneth Perry" : "Kenneth Perry. Show system sigil"
      );
    });
  });
</script>
