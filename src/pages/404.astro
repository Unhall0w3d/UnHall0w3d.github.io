---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Signal not found" description="The requested NOC Thoughts signal could not be located.">
  <section class="error-page">
    <p class="error-code">404 // LOST SIGNAL</p>
    <h1>Nothing answers on this frequency.</h1>
    <p>The address may be outdated, mistyped, or lost somewhere between the old machinery and the new archive.</p>
    <a class="button button-primary" href="/posts.html">Search the archive</a>
  </section>
</BaseLayout>
