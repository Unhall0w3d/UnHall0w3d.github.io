---
import { site } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  type?: "website" | "article";
  publishedTime?: string;
}

const {
  title = site.title,
  description = site.description,
  type = "website",
  publishedTime
} = Astro.props;

const canonicalPath = Astro.url.pathname.replace(/index\.html$/, "") || "/";
const canonical = new URL(canonicalPath, site.url);
const documentTitle = title === site.title ? title : `${title} | ${site.name}`;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#070913" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content={site.verification.google} />
    <meta name="msvalidate.01" content={site.verification.bing} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} RSS feed`} href="/feed.xml" />
    <link rel="icon" href="/favicon.ico?v=2" sizes="any" />
    <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png?v=2" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png?v=2" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest?v=2" />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <title>{documentTitle}</title>
    <script is:inline async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${site.integrations.adsensePublisher}`} crossorigin="anonymous"></script>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${site.integrations.googleAnalytics}`}></script>
    <script is:inline define:vars={{ measurementId: site.integrations.googleAnalytics }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', measurementId);
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="ambient-grid" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="/" aria-label="NOC Thoughts home">
        <svg class="brand-sigil" viewBox="0 0 48 48" aria-hidden="true">
          <path d="M24 3 42 14v20L24 45 6 34V14L24 3Z" />
          <path d="m16 30 8-14 8 14M17 25h14" />
        </svg>
        <span class="brand-copy">
          <strong>{site.name}</strong>
          <small>FIELD NOTES // SIGNAL 01</small>
        </span>
      </a>

      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/posts.html">Archive</a>
        <a href="/categories.html">Categories</a>
        <a href="/tags.html">Tags</a>
        <a href="/about.html">Operator</a>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        <span class="status-light" aria-hidden="true"></span>
        Signal maintained by {site.author.name}
      </p>
      <p class="footer-code">NOCTHOUGHTS // SYRACUSE, NY // {new Date().getFullYear()}</p>
      <nav class="footer-links" aria-label="Footer links">
        <a href="/feed.xml">RSS</a>
        <a href="/privacypolicy.html">Privacy</a>
        <a href={site.social.github}>GitHub</a>
      </nav>
    </footer>
  </body>
</html>
