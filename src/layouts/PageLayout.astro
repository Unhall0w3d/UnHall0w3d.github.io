---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description, eyebrow = "NOC THOUGHTS // REFERENCE NODE" } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="page-hero">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    {description && <p class="page-deck">{description}</p>}
  </header>
  <div class="page-shell prose">
    <slot />
  </div>
</BaseLayout>
